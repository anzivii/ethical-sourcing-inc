{
  "manifest_version": 3,
  "name": "Ethical Sourcing Tool",
  "version": "1.0",
  "description": "Scans websites and alerts users to ethical sourcing ratings.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "hello_extension1.jpeg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["brands.json"],
      "matches": ["<all_urls>"]
    }
  ]
}